{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/booking", "destination": "/booking" },
    { "source": "/((?!api/|_next/).*)", "destination": "/index.html" }
  ],
  "github": {
    "silent": true
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
